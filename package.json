{
  "name": "grants-payment-service",
  "version": "0.0.0",
  "description": "grants-payment-service",
  "main": "src/index.js",
  "type": "module",
  "imports": {
    "#~/*": "./src/*"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "AWS_EMF_ENVIRONMENT=Local NODE_ENV=development npm run server:watch",
    "dev:debug": "AWS_EMF_ENVIRONMENT=Local NODE_ENV=development npm run server:debug",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "commitlint": "commitlint --edit",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "npm run setup:husky",
    "security-audit": "npm audit --audit-level=high",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "npm run test:defaults -- run --coverage --exclude '**/contracts/**'",
    "test:defaults": "TZ=UTC HTTP_PROXY=http://localhost:8080 NODE_USE_ENV_PROXY=1 vitest",
    "test:watch": "npm run test:defaults -- --exclude '**/contracts/**'",
    "test:contracts": "npm run test:defaults -- run src/contracts",
    "test:contracts:consumer": "npm run test:defaults -- run src/contracts/consumer",
    "test:contracts:provider": "npm run test:defaults -- run src/contracts/provider"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-sns": "3.1075.0",
    "@aws-sdk/client-sqs": "3.1075.0",
    "@aws-sdk/credential-providers": "3.1075.0",
    "@defra/cdp-metrics": "0.6.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "croner": "10.0.1",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "4.0.0",
    "joi": "18.2.3",
    "mongoose": "9.7.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sqs-consumer": "15.0.2"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@commitlint/cli": "21.1.0",
    "@pact-foundation/pact": "17.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.2",
    "aws-sdk-client-mock": "4.1.0",
    "eslint": "9.39.4",
    "eslint-plugin-import-x": "4.16.2",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.9.4",
    "proxy-chain": "3.0.0",
    "vitest": "4.1.9",
    "vitest-fetch-mock": "0.4.5",
    "vitest-mongodb": "1.0.3"
  }
}
